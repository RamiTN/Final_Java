<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LandingController"
      stylesheets="@/css/style.css"
      prefWidth="1200" prefHeight="800"
      styleClass="landing-root">

    <!-- ═══════════ NAVIGATION BAR ═══════════ -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="landing-navbar">
        <padding><Insets top="0" right="48" bottom="0" left="48"/></padding>

        <Label text="⚡ CVBuilder" styleClass="landing-logo"/>

        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="28" alignment="CENTER_RIGHT" styleClass="landing-nav-links">
            <Label text="Features" styleClass="landing-nav-link" onMouseClicked="#scrollToFeatures"/>
            <Label text="How It Works" styleClass="landing-nav-link"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Sign In" onAction="#goToLogin" styleClass="landing-signin-btn"/>
            <Button text="Get Started" onAction="#goToRegister" styleClass="landing-cta-btn"/>
        </HBox>
    </HBox>

    <!-- ═══════════ SCROLLABLE CONTENT ═══════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">

        <VBox styleClass="landing-content" spacing="0">

            <!-- ═══════════ HERO SECTION ═══════════ -->
            <VBox alignment="CENTER" spacing="20" styleClass="landing-hero">
                <padding><Insets top="80" right="60" bottom="80" left="60"/></padding>

                <Label text="Build Your Dream CV" styleClass="landing-hero-title"/>
                <Label text="in Minutes, Not Hours" styleClass="landing-hero-title-accent"/>

                <Label text="Create professional, polished resumes with AI-powered suggestions.&#10;Browse jobs, practice interviews, and export to PDF — all in one place."
                       styleClass="landing-hero-subtitle" wrapText="true" maxWidth="680" alignment="CENTER"
                       textAlignment="CENTER"/>

                <HBox alignment="CENTER" spacing="16">
                    <padding><Insets top="12" right="0" bottom="0" left="0"/></padding>
                    <Button text="Create Your CV Now" onAction="#goToRegister" styleClass="landing-hero-btn"/>
                </HBox>

                <!-- DYNAMIC stats from DB -->
                <HBox alignment="CENTER" spacing="60" styleClass="landing-hero-stats">
                    <padding><Insets top="36" right="0" bottom="0" left="0"/></padding>

                    <VBox alignment="CENTER" spacing="2">
                        <Label fx:id="statUsersLabel" text="—" styleClass="landing-hero-stat-number"/>
                        <Label text="Registered Users" styleClass="landing-hero-stat-label"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2">
                        <Label fx:id="statCvsLabel" text="—" styleClass="landing-hero-stat-number"/>
                        <Label text="CVs Created" styleClass="landing-hero-stat-label"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2">
                        <Label fx:id="statJobsLabel" text="—" styleClass="landing-hero-stat-number"/>
                        <Label text="Jobs Available" styleClass="landing-hero-stat-label"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ═══════════ FEATURES SECTION ═══════════ -->
            <VBox fx:id="featuresSection" alignment="CENTER" spacing="40" styleClass="landing-features-section">
                <padding><Insets top="80" right="60" bottom="80" left="60"/></padding>

                <Label text="What You Can Do" styleClass="landing-section-title"/>
                <Label text="Real features, built into the app" styleClass="landing-section-subtitle"/>

                <HBox spacing="24" alignment="CENTER">
                    <VBox styleClass="landing-feature-card" HBox.hgrow="ALWAYS" maxWidth="320">
                        <Label text="🤖" styleClass="landing-feature-icon"/>
                        <Label text="AI-Powered CV Advice" styleClass="landing-feature-title"/>
                        <Label text="Get personalized suggestions from Gemini AI to improve each section of your CV — objective, skills, experience, and more."
                               styleClass="landing-feature-desc" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="landing-feature-card" HBox.hgrow="ALWAYS" maxWidth="320">
                        <Label text="📄" styleClass="landing-feature-icon"/>
                        <Label text="CV Builder &amp; PDF Export" styleClass="landing-feature-title"/>
                        <Label text="Create multiple CVs with a structured form — personal info, education, experience, skills, and languages. Export as a professional PDF."
                               styleClass="landing-feature-desc" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="landing-feature-card" HBox.hgrow="ALWAYS" maxWidth="320">
                        <Label text="🎯" styleClass="landing-feature-icon"/>
                        <Label text="Smart Job Matching" styleClass="landing-feature-title"/>
                        <Label text="Browse available job offers and let the app match your skills to the best opportunities automatically."
                               styleClass="landing-feature-desc" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="24" alignment="CENTER">
                    <VBox styleClass="landing-feature-card" HBox.hgrow="ALWAYS" maxWidth="320">
                        <Label text="💬" styleClass="landing-feature-icon"/>
                        <Label text="Interview Practice" styleClass="landing-feature-title"/>
                        <Label text="Practice common interview questions with the AI JobGuide chatbot. Get real-time feedback and model answers to sharpen your skills."
                               styleClass="landing-feature-desc" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="landing-feature-card" HBox.hgrow="ALWAYS" maxWidth="320">
                        <Label text="📊" styleClass="landing-feature-icon"/>
                        <Label text="Admin Dashboard" styleClass="landing-feature-title"/>
                        <Label text="Admins get a full management panel — user &amp; job CRUD, role distribution pie charts, company analytics, and CSV exports."
                               styleClass="landing-feature-desc" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="landing-feature-card" HBox.hgrow="ALWAYS" maxWidth="320">
                        <Label text="👤" styleClass="landing-feature-icon"/>
                        <Label text="User Profiles &amp; Roles" styleClass="landing-feature-title"/>
                        <Label text="User and admin roles with separate dashboards. View your profile, track your CVs, and manage your career from one place."
                               styleClass="landing-feature-desc" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ═══════════ HOW IT WORKS ═══════════ -->
            <VBox alignment="CENTER" spacing="40" styleClass="landing-steps-section">
                <padding><Insets top="80" right="60" bottom="80" left="60"/></padding>

                <Label text="How It Works" styleClass="landing-section-title"/>
                <Label text="Three steps to your next opportunity" styleClass="landing-section-subtitle"/>

                <HBox spacing="32" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="14" HBox.hgrow="ALWAYS" maxWidth="280" styleClass="landing-step-card">
                        <StackPane styleClass="landing-step-circle">
                            <Label text="1" styleClass="landing-step-number"/>
                        </StackPane>
                        <Label text="Register" styleClass="landing-step-title"/>
                        <Label text="Create your free account with a name, email, and password. You're in."
                               styleClass="landing-step-desc" wrapText="true" textAlignment="CENTER"/>
                    </VBox>

                    <Label text="→" styleClass="landing-step-arrow"/>

                    <VBox alignment="CENTER" spacing="14" HBox.hgrow="ALWAYS" maxWidth="280" styleClass="landing-step-card">
                        <StackPane styleClass="landing-step-circle">
                            <Label text="2" styleClass="landing-step-number"/>
                        </StackPane>
                        <Label text="Build Your CV" styleClass="landing-step-title"/>
                        <Label text="Fill in your details, add skills and experience, then let the AI polish it for you."
                               styleClass="landing-step-desc" wrapText="true" textAlignment="CENTER"/>
                    </VBox>

                    <Label text="→" styleClass="landing-step-arrow"/>

                    <VBox alignment="CENTER" spacing="14" HBox.hgrow="ALWAYS" maxWidth="280" styleClass="landing-step-card">
                        <StackPane styleClass="landing-step-circle">
                            <Label text="3" styleClass="landing-step-number"/>
                        </StackPane>
                        <Label text="Apply &amp; Practice" styleClass="landing-step-title"/>
                        <Label text="Browse matched jobs, practice interviews with the AI coach, and export your CV as PDF."
                               styleClass="landing-step-desc" wrapText="true" textAlignment="CENTER"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ═══════════ RECENT JOBS (DYNAMIC) ═══════════ -->
            <VBox alignment="CENTER" spacing="24" styleClass="landing-features-section">
                <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

                <Label text="Latest Job Offers" styleClass="landing-section-title"/>
                <Label fx:id="jobsSectionSubtitle" text="Loading..." styleClass="landing-section-subtitle"/>

                <VBox fx:id="recentJobsContainer" spacing="12" maxWidth="800"/>

                <Button text="Sign Up to Apply" onAction="#goToRegister" styleClass="landing-cta-btn"
                        style="-fx-padding: 10 28;"/>
            </VBox>

            <!-- ═══════════ FINAL CTA ═══════════ -->
            <VBox alignment="CENTER" spacing="20" styleClass="landing-cta-section">
                <padding><Insets top="70" right="60" bottom="70" left="60"/></padding>

                <Label text="Ready to Build Your CV?" styleClass="landing-cta-title"/>
                <Label fx:id="ctaSubtitleLabel" text="Join our community and start building your career today."
                       styleClass="landing-cta-subtitle" wrapText="true" maxWidth="560" textAlignment="CENTER"/>

                <HBox alignment="CENTER" spacing="16">
                    <padding><Insets top="8" right="0" bottom="0" left="0"/></padding>
                    <Button text="Create Your Account" onAction="#goToRegister" styleClass="landing-cta-big-btn"/>
                </HBox>
            </VBox>

            <!-- ═══════════ FOOTER ═══════════ -->
            <HBox alignment="CENTER" spacing="32" styleClass="landing-footer">
                <padding><Insets top="20" right="48" bottom="20" left="48"/></padding>

                <Label text="© 2026 CVBuilder — Built with JavaFX" styleClass="landing-footer-text"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

        </VBox>

    </ScrollPane>

</VBox>
