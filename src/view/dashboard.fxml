<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.UserController"
      style="-fx-background-color: #2b2b2b; -fx-padding: 40;">

    <Label fx:id="welcomeLabel" text="Welcome!" style="-fx-font-size: 28; -fx-text-fill: #e0e0e0; -fx-font-weight: bold;"/>
    <Label text="What would you like to do?" style="-fx-font-size: 14; -fx-text-fill: #aaa;"/>

    <HBox alignment="CENTER" spacing="15">
        <Button text="My CVs" onAction="#goToCv" prefWidth="140" prefHeight="70"
                style="-fx-background-color: #4a9eff; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"/>
        <Button text="Profile" onAction="#goToProfile" prefWidth="140" prefHeight="70"
                style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"/>
        <Button text="Jobs" onAction="#goToJobs" prefWidth="140" prefHeight="70"
                style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="15">
        <Button text="Job Guide" onAction="#goToJobGuide" prefWidth="140" prefHeight="70"
                style="-fx-background-color: #fdcb6e; -fx-text-fill: #2b2b2b; -fx-font-size: 14; -fx-cursor: hand;"/>
        <Button fx:id="adminBtn" text="Admin Panel" onAction="#goToAdmin" prefWidth="140" prefHeight="70"
                style="-fx-background-color: #e17055; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;"
                visible="false" managed="false"/>
    </HBox>

    <Button text="Logout" onAction="#handleLogout"
            style="-fx-background-color: #636e72; -fx-text-fill: white; -fx-padding: 8 30; -fx-cursor: hand;"/>
</VBox>
