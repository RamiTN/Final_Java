<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.UserController"
      stylesheets="@/css/style.css"
      prefWidth="1000" prefHeight="650"
      styleClass="root">

    <HBox VBox.vgrow="ALWAYS">

        <!-- SIDEBAR -->
        <VBox styleClass="sidebar">
            <Label text="CVBuilder" styleClass="logo"/>
            <Button text="Dashboard" onAction="#goToDashboard" maxWidth="Infinity" styleClass="nav-btn"/>
            <Button text="Create CV" onAction="#goToCv" maxWidth="Infinity" styleClass="nav-btn"/>
            <Button text="Profile" maxWidth="Infinity" styleClass="nav-btn, active"/>
            <Button text="Jobs" onAction="#goToJobs" maxWidth="Infinity" styleClass="nav-btn"/>
            <Button text="Job Guide" onAction="#goToJobGuide" maxWidth="Infinity" styleClass="nav-btn"/>
            <Button fx:id="adminBtn" text="Admin Panel" onAction="#goToAdmin" maxWidth="Infinity"
                    styleClass="nav-btn" visible="false" managed="false"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            <Button text="Sign out" onAction="#handleLogout" maxWidth="Infinity" styleClass="logout-btn"/>
        </VBox>

        <!-- MAIN CONTENT -->
        <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox styleClass="main" alignment="CENTER" spacing="20">

            <Label text="My Profile" styleClass="page-title"/>

            <!-- PROFILE CARD -->
            <VBox styleClass="profile-card" alignment="CENTER" spacing="14"
                  style="-fx-max-width: 500; -fx-padding: 30;">

                <!-- AVATAR -->
                <VBox alignment="CENTER" spacing="10">
                    <ImageView fx:id="profileImageView" fitWidth="100" fitHeight="100"
                               preserveRatio="true"
                               style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 2);"/>
                    <Button text="📷 Change Photo" onAction="#handleUploadPicture" styleClass="small-btn"/>
                </VBox>

                <Separator/>

                <!-- READ-ONLY INFO -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="NAME" styleClass="profile-field-label"/>
                        <Label fx:id="profileNameLabel" styleClass="profile-field-value"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="EMAIL" styleClass="profile-field-label"/>
                        <Label fx:id="profileEmailLabel" styleClass="profile-field-value"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="ROLE" styleClass="profile-field-label"/>
                        <Label fx:id="profileRoleLabel" styleClass="profile-role-badge"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="BIO" styleClass="profile-field-label"/>
                        <Label fx:id="profileBioLabel" styleClass="subtitle" wrapText="true"/>
                    </VBox>
                </HBox>

                <Separator/>

                <!-- EDIT FIELDS (hidden by default) -->
                <VBox fx:id="editFieldsBox" spacing="10" visible="false" managed="false">
                    <Label text="EDIT PROFILE" styleClass="panel-title"/>
                    <VBox spacing="4">
                        <Label text="NAME" styleClass="form-label"/>
                        <TextField fx:id="editNameField" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="EMAIL" styleClass="form-label"/>
                        <TextField fx:id="editEmailField" styleClass="form-field"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="BIO" styleClass="form-label"/>
                        <TextArea fx:id="editBioField" promptText="Tell us about yourself..."
                                  prefRowCount="3" wrapText="true" styleClass="form-area"/>
                    </VBox>
                    <Button text="✔ Save Changes" onAction="#handleSaveProfile" styleClass="success-btn"/>
                </VBox>

                <!-- ACTIONS -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="✏ Edit Profile" onAction="#handleToggleEdit" styleClass="accent-btn"/>
                    <Button text="💬 Help &amp; Support" onAction="#handleSendSupport" styleClass="info-btn"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🗑 Delete Profile" onAction="#handleDeleteProfile" styleClass="danger-btn"/>
                </HBox>

                <Label fx:id="messageLabel" styleClass="message-label"/>

            </VBox>

        </VBox>
        </ScrollPane>

    </HBox>

</VBox>
