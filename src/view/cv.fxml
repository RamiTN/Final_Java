<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.CVController"
      style="-fx-background-color: #2b2b2b; -fx-padding: 20;">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="Back" onAction="#goToDashboard"
                style="-fx-background-color: #636e72; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Label text="My CVs" style="-fx-font-size: 22; -fx-text-fill: #e0e0e0; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Select CV:" style="-fx-text-fill: #aaa;"/>
        <ComboBox fx:id="cvCombo" promptText="-- New CV --" onAction="#handleSelectCv"
                  style="-fx-background-color: #3c3c3c;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: #2b2b2b; -fx-border-color: transparent;">
        <VBox spacing="8" style="-fx-padding: 10;">
            <TextField fx:id="fullNameField" promptText="Full Name"
                       style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-padding: 8;"/>
            <TextField fx:id="cvEmailField" promptText="Email"
                       style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-padding: 8;"/>
            <TextField fx:id="phoneField" promptText="Phone"
                       style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-padding: 8;"/>
            <TextField fx:id="addressField" promptText="Address"
                       style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-padding: 8;"/>
            <TextArea fx:id="objectiveField" promptText="Career Objective" prefRowCount="2" wrapText="true"
                      style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <TextArea fx:id="educationField" promptText="Education" prefRowCount="2" wrapText="true"
                      style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <TextArea fx:id="experienceField" promptText="Experience" prefRowCount="2" wrapText="true"
                      style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <TextArea fx:id="skillsField" promptText="Skills (comma separated)" prefRowCount="2" wrapText="true"
                      style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <TextArea fx:id="languagesField" promptText="Languages" prefRowCount="2" wrapText="true"
                      style="-fx-background-color: #3c3c3c; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Create" onAction="#handleCreate"
                        style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="Update" onAction="#handleUpdate"
                        style="-fx-background-color: #fdcb6e; -fx-text-fill: #2b2b2b; -fx-cursor: hand;"/>
                <Button text="Delete" onAction="#handleDelete"
                        style="-fx-background-color: #e17055; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="Download PDF" onAction="#handleDownload"
                        style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="AI Advice" onAction="#handleAiAdvice"
                        style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>

            <Label fx:id="messageLabel" style="-fx-text-fill: #ff6b6b;"/>
            <Label text="AI Advice:" style="-fx-text-fill: #aaa;"/>
            <TextArea fx:id="aiAdviceArea" editable="false" prefRowCount="4" wrapText="true"
                      promptText="AI suggestions will appear here..."
                      style="-fx-background-color: #3c3c3c; -fx-text-fill: #a0e6a0; -fx-prompt-text-fill: #666;"/>
        </VBox>
    </ScrollPane>
</VBox>
